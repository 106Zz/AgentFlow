<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.agenthub.api.search.mapper.VectorStoreDocMapper">

    <!--
        批量查询文档内容（按 internal_id 列表）
        注意：bm25_term_freq.doc_id 存储的是 metadata.internal_id（业务标识）
        不是 vector_store.id（数据库主键 UUID）
    -->
    <select id="selectByIds" resultType="com.agenthub.api.search.domain.VectorStoreDoc">
        SELECT id, content, metadata
        FROM vector_store
        WHERE metadata->>'internal_id' = ANY(
        <foreach collection="ids" item="id" open="ARRAY[" separator="," close="]">
            #{id}
        </foreach>
        )
    </select>

</mapper>
